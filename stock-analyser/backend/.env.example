# Environment overrides (optional)
# Copy this file to .env and fill in as needed.

APP_NAME=Indian Stock Analyser
DEBUG=False
ENABLE_SCHEDULER=True
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

TIMEZONE=Asia/Kolkata
PRE_MARKET_ANALYSIS_TIME=08:30

MAX_RECOMMENDATIONS=10
MIN_SCORE_THRESHOLD=45
MIN_MARKET_CAP_CR=500

MAX_STOP_LOSS_PCT=2.0
MIN_STOP_LOSS_PCT=0.4
TARGET1_RR_RATIO=1.5
TARGET2_RR_RATIO=2.5

TRADING_BROKER=upstox
TRADING_MODE=paper
ALLOW_LIVE_TRADING=False
PAPER_STARTING_CAPITAL=100000
DEFAULT_CAPITAL_PER_TRADE=10000
MAX_DAILY_LOSS_PCT=2.0
MAX_OPEN_POSITIONS=3
MAX_POSITION_VALUE=15000
MAX_TRADES_PER_DAY=5
AUTO_SQUARE_OFF_TIME=15:20

UPSTOX_API_BASE_URL=https://api-hft.upstox.com/v2
UPSTOX_ACCESS_TOKEN=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

DB_PATH=stock_analyser.db
DATABASE_URL=postgresql://user:password@host:5432/database_name
